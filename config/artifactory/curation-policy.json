{
  "name": "block-malicious-ai-models",
  "description": "Block Hugging Face models with malicious payloads or critical vulnerabilities.",
  "type": "security",
  "rules": [
    {
      "name": "block-critical-cves",
      "priority": 1,
      "criteria": {
        "min_severity": "Critical",
        "fix_version_dependant": false,
        "malicious_package": false
      },
      "actions": {
        "block_download": {
          "active": true,
          "unscanned": false
        }
      }
    },
    {
      "name": "block-malicious-packages",
      "priority": 2,
      "criteria": {
        "malicious_package": true
      },
      "actions": {
        "block_download": {
          "active": true,
          "unscanned": true
        }
      }
    }
  ]
}
