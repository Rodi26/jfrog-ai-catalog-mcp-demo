{
  "name": "ai-catalog-security-policy",
  "description": "Xray security policy for AI and Machine Learning artifacts. Scans for malicious code and CVEs in all AI assets.",
  "type": "security",
  "rules": [
    {
      "name": "block-critical-vulnerabilities",
      "priority": 1,
      "criteria": {
        "min_severity": "Critical",
        "fix_version_dependant": false,
        "malicious_package": false
      },
      "actions": {
        "fail_build": true,
        "block_download": {
          "active": true,
          "unscanned": false
        }
      }
    },
    {
      "name": "block-malicious-code",
      "priority": 2,
      "criteria": {
        "malicious_package": true
      },
      "actions": {
        "fail_build": true,
        "block_download": {
          "active": true,
          "unscanned": true
        }
      }
    },
    {
      "name": "warn-high-vulnerabilities",
      "priority": 3,
      "criteria": {
        "min_severity": "High",
        "fix_version_dependant": false,
        "malicious_package": false
      },
      "actions": {
        "fail_build": false,
        "block_download": {
          "active": false,
          "unscanned": false
        }
      }
    }
  ]
}
